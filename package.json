    "js-yaml": "^4.1.1",
    "mysql2": "^3.18.2",
    "node-notifier": "^10.0.1",
    "otplib": "^13.3.0",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
