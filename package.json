    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "cpx": "^1.2.1",
    "electron": "^40.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/csurf": "^1.11.5",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.3",
