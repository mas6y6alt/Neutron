{
  "name": "Neutron",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "npm run build-client && npm run build-ts && npm run copy-assets",
    "build-ts": "tsc --outDir dist",
    "build-client": "vite build",
    "copy-assets": "cpx \"src/server/{templates,assets,static}/**/*.{yml,html,css,js,png,jpg,svg}\" dist/server",
    "start:server": "npm run clean && npm run build && node ./dist/index.js",
    "test:server": "npm run clean && npm run build && node ./dist/index.js --config test/config.yml",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
