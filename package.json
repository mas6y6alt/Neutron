{
  "name": "Neutron",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "npm run build-ts && npm run copy-assets",
    "build-ts": "tsc --outDir dist",
    "copy-assets": "cpx \"src/server/{templates,static}/**/*.{html,css,js,png,jpg,svg}\" dist/server",
    "start:server": "npm run build && node ./dist/index.js",
    "test:server": "npm run build && node ./dist/index.js --config test/config.yml",
    "package": "node scripts/compile.js",
    "clean": "rimraf dist package"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.2",
    "@types/pg": "^8.16.0",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.18.1",
    "cpx": "^1.2.1",
    "electron": "^40.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.18.2",
    "node-notifier": "^10.0.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1"
  }
}
